<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.biblemarker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Render into display cutout areas; CSS safe-area-inset handles avoidance -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>
        <!-- Bars are made transparent by enableEdgeToEdge() in MainActivity.
             android:statusBarColor / navigationBarColor are deprecated and ignored on API 35+. -->
        <item name="android:windowContentOverlay">@null</item>
    </style>
</resources>
