<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>app.biblemarker.BibleMarker</id>
  <name>BibleMarker</name>
  <summary>Inductive Bible study with marking, observation, and notes</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>

  <developer id="com.spearssoftware">
    <name>Spears Software</name>
  </developer>

  <description>
    <p>
      BibleMarker is a Bible study app built around inductive observation.
      Mark the text, capture what you see, and develop your own
      cross-references over time.
    </p>
    <p>Features:</p>
    <ul>
      <li>Multi-translation reading with the American Standard Version included and many more available as free downloads (NASB, KJV, BSB, and others)</li>
      <li>Verse marking with custom keywords, colors, and symbols</li>
      <li>Observations, notes, and structured study worksheets</li>
      <li>Reference tools: Strong's, Hebrew and Greek breakdowns, cross-references, and chapter people and places</li>
      <li>Works offline</li>
    </ul>
  </description>

  <launchable type="desktop-id">app.biblemarker.BibleMarker.desktop</launchable>

  <url type="homepage">https://biblemarker.app</url>
  <url type="bugtracker">https://github.com/spearssoftware/BibleMarker/issues</url>
  <url type="vcs-browser">https://github.com/spearssoftware/BibleMarker</url>
  <url type="contribute">https://github.com/spearssoftware/BibleMarker/blob/main/CONTRIBUTING.md</url>

